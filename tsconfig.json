{
  "compilerOptions": {
    "module": "nodenext",       
    "target": "esnext",        
    "moduleResolution": "nodenext", 
    "esModuleInterop": true,   
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "skipLibCheck": true
  }
}